{
  "name": "printdown",
  "version": "1.7.4",
  "description": "Markdown viewer with MathJax rendering, PDF export, and printing",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "webpack --mode development && electron .",
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "clean": "node -e \"const fs = require('fs'); ['dist', 'release'].forEach(dir => fs.rmSync(dir, {recursive:true, force:true}));\"",
    "generate-icons": "node generate-icons.js",
    "prepare-build": "node generate-build-icons.js",
    "rebuild-icons": "npm run prepare-build && npm run build",
    "pack": "npm run build && electron-builder --dir",
    "postpack": "node scripts/configure-fuses.js && node scripts/fix-asar-integrity.js",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:dev": "playwright test",
    "test:update-snapshots": "playwright test --update-snapshots",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed"
  },
  "keywords": [
    "markdown",
    "mathjax",
    "electron",
    "pdf"
  ],
  "author": {
    "name": "Narayan Ambatipudi",
    "email": "110836089+nambatipudi@users.noreply.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@playwright/test": "^1.59.1",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.18.13",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^6.8.1",
    "electron": "^39.0.0",
    "electron-builder": "^25.1.8",
    "electron-for-testing": "npm:electron@^31.7.7",
    "electron-store": "^8.1.0",
    "electron-test-30": "npm:electron@^30.5.1",
    "google-fonts-helper": "^3.7.3",
    "html-webpack-plugin": "^5.5.4",
    "patch-package": "^8.0.1",
    "sharp": "^0.34.4",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.19.1",
    "@codemirror/commands": "^6.10.0",
    "@codemirror/history": "^0.19.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.7",
    "@maxgraph/core": "^0.23.0",
    "dompurify": "^3.2.6",
    "markdown-it": "^14.1.0",
    "markdown-it-texmath": "^1.0.0",
    "mathjax": "^3.2.2",
    "mermaid": "^11.12.1",
    "raphael": "^2.3.0",
    "underscore": "^1.13.7"
  },
  "build": {
    "appId": "com.printdown.app",
    "productName": "Print Down",
    "copyright": "Copyright © 2025",
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "icon.png",
      "package.json"
    ],
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "role": "Editor"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PrintDown"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon-mac.png",
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icons",
      "category": "Office",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    }
  }
}
